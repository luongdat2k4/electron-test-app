{
  "name": "electron-vue-app",
  "version": "1.0.0",
  "description": "Electron + Vue 3 + Vite + TypeScript + TailwindCSS Desktop App",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.js dev",
    "build": "node scripts/dev.js build",
    "preview": "node scripts/dev.js preview"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3",
    "vite": "^5.1.6",
    "vue-tsc": "^2.0.6"
  },
  "build": {
    "appId": "com.electron.vue-app",
    "productName": "ElectronVueApp",
    "files": [
      "out/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
